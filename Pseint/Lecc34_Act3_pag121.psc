Algoritmo Lecc34_Act3_pag121
	Definir c,f,k Como Real
	Escribir "Ingrese la cantidad en grados centigrados: '
	Leer c
	f=(c*1.8)+32
	k=c+273.15
	
	Escribir "La cantidad de grados celsius es de: ",c
	Escribir "La cantidad de grados farhenheit es de: ",f
	Escribir "La cantidad de grados kelvin es de: ",k
FinAlgoritmo
